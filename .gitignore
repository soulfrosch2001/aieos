# Node tooling (audio generator, etc.) — installed locally, never committed.
node_modules/
npm-debug.log*

# Generated working files
*.log

# Native installer build output (the .exe / .pkg are built by CI, never committed)
installer/Output/
installer/macos/build/
installer/macos/Output/
# The clickable launcher exe (compiled from aieos-launcher.ps1 by PS2EXE in CI).
installer/AIEOS.exe
*.exe
*.pkg

# Personal / non-summary audio must NEVER be published — only the NNNN-resumo.* decision
# summaries belong in the public repo. (A personal voice recording leaked here once.)
government/decisions/resumo/audio/*.m4a
government/decisions/resumo/audio/*.wav

# Memory ledger — captured conversation summaries stay LOCAL (never pushed to a public repo).
# Only the folder docs are tracked; the dated session entries are not.
memory/ledger/*.md
!memory/ledger/README.md

# Memory ledger quarantine — guard-flagged captures held for human review, never published.
memory/ledger/quarantine/*
!memory/ledger/quarantine/README.md

# Forge runtime artifacts (run traces + agent scratch workspaces)
forge/runs/*.json
forge/examples/*/workspace/
forge/sandboxes/*
!forge/sandboxes/README.md

# Support-mode summaries (e.g. OUROBOROS) — produced when AIEOS supports ANOTHER
# project; the rule doc stays tracked, the summaries themselves stay out of this repo.
resumo/*
!resumo/README.md

.aieos_config.json

*.gguf
